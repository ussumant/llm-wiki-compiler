#!/usr/bin/env bash
# SessionStart hook for llm-wiki-compiler plugin
# Detects .wiki-compiler.json and injects wiki context based on mode

set -euo pipefail

# Walk up from $PWD to find .wiki-compiler.json
config_file=""
dir="$PWD"
while [ "$dir" != "/" ]; do
  if [ -f "$dir/.wiki-compiler.json" ]; then
    config_file="$dir/.wiki-compiler.json"
    break
  fi
  dir="$(dirname "$dir")"
done

# No config found — exit silently (plugin installed but project has no wiki)
if [ -z "$config_file" ]; then
  exit 0
fi

project_root="$(dirname "$config_file")"

# Read config values using node
output_path=$(node -e "const c=require('$config_file'); console.log(c.output || '')")
mode=$(node -e "const c=require('$config_file'); console.log(c.mode || 'staging')")
name=$(node -e "const c=require('$config_file'); console.log(c.name || 'Project')")

if [ -z "$output_path" ]; then
  exit 0
fi

index_file="$project_root/$output_path/INDEX.md"
state_file="$project_root/$output_path/.compile-state.json"

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

if [ ! -f "$index_file" ]; then
  context="[Wiki Compiler] Wiki configured for \"$name\" but not yet compiled. Run /wiki-compile to build your knowledge base."
else
  topic_count=$(node -e "const s=require('$state_file'); console.log((s.topics||[]).length)" 2>/dev/null || echo "?")
  last_compiled=$(node -e "const s=require('$state_file'); console.log(s.last_compiled || 'unknown')" 2>/dev/null || echo "unknown")

  case "$mode" in
    staging)
      context="[Wiki Compiler] A compiled knowledge wiki is available for \"$name\".\nLocation: $output_path\nTopics: $topic_count | Last compiled: $last_compiled\nMode: staging (supplements existing context)\n\nWhen you need deep context on a topic, read ${output_path}INDEX.md to see available topics, then read specific topic articles. This wiki synthesizes source files into topic-based briefings — reading one topic article replaces reading 10-20 raw files.\n\nWiki articles are read-only synthesis. Never modify wiki/ files directly — they are regenerated by /wiki-compile."
      ;;
    recommended)
      context="[Wiki Compiler] \"$name\" knowledge wiki active.\nLocation: $output_path\nTopics: $topic_count | Last compiled: $last_compiled\nMode: recommended\n\nFor project context, start with ${output_path}INDEX.md. Read topic articles before reading raw source files. Fall back to raw sources only when the wiki article is insufficient or you need granular detail.\n\nWiki articles are read-only synthesis — regenerated by /wiki-compile."
      ;;
    primary)
      context="[Wiki Compiler] \"$name\" wiki is the primary knowledge source.\nLocation: $output_path\nTopics: $topic_count | Last compiled: $last_compiled\n\nRead ${output_path}INDEX.md at session start. Only read raw source files when a wiki article's Sources section points you there for detail.\n\nWiki articles are read-only synthesis — regenerated by /wiki-compile."
      ;;
    *)
      context="[Wiki Compiler] Wiki available for \"$name\" at $output_path ($topic_count topics, last compiled: $last_compiled). Run /wiki-compile to update."
      ;;
  esac
fi

escaped_context=$(escape_for_json "$context")

# Output in correct format per platform
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$escaped_context"
fi

exit 0
