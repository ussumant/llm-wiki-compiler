#!/usr/bin/env bash
# Stop hook — when Claude session ends, check if wiki is stale.
# If source files were modified during this session but wiki wasn't recompiled,
# output a reminder so Claude mentions it before signing off.

set -euo pipefail

# Find .wiki-compiler.json
config_file=""
dir="$PWD"
while [ "$dir" != "/" ]; do
  if [ -f "$dir/.wiki-compiler.json" ]; then
    config_file="$dir/.wiki-compiler.json"
    break
  fi
  dir="$(dirname "$dir")"
done

[ -z "$config_file" ] && exit 0

project_root="$(dirname "$config_file")"
output_path=$(python3 -c "import json; print(json.load(open('$config_file')).get('output',''))" 2>/dev/null || echo "")
[ -z "$output_path" ] && exit 0

state_file="$project_root/$output_path/.compile-state.json"
[ ! -f "$state_file" ] && exit 0

last_compiled=$(python3 -c "import json; print(json.load(open('$state_file')).get('last_compiled',''))" 2>/dev/null || echo "")
[ -z "$last_compiled" ] && exit 0

# Check if any source files are newer than the compile state file
stale_count=0
stale_files=""

# Get source directories
source_dirs=$(python3 -c "
import json
c = json.load(open('$config_file'))
for s in c.get('sources', []):
    p = s.get('path', '')
    if p.startswith('/'):
        print(p)
    else:
        print('$project_root/' + p)
" 2>/dev/null || echo "")

file_types=$(python3 -c "
import json
c = json.load(open('$config_file'))
print(' '.join(c.get('file_types', ['.md'])))
" 2>/dev/null || echo ".md")

for sd in $source_dirs; do
  [ ! -d "$sd" ] && continue
  for ext in $file_types; do
    while IFS= read -r -d '' f; do
      if [ "$f" -nt "$state_file" ]; then
        stale_count=$((stale_count + 1))
        stale_files="$stale_files\n- $(basename "$f")"
      fi
    done < <(find "$sd" -name "*${ext}" -print0 2>/dev/null)
  done
done

if [ "$stale_count" -gt 0 ]; then
  msg="[Wiki Compiler] ⚠ Wiki is stale: ${stale_count} source file(s) changed since last compile (${last_compiled}). Run /wiki-compile next session to update."
  msg="${msg//\\/\\\\}"
  msg="${msg//\"/\\\"}"
  msg="${msg//$'\n'/\\n}"

  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "Stop",\n    "additionalContext": "%s"\n  }\n}\n' "$msg"
fi

exit 0
