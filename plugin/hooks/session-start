#!/usr/bin/env bash
# SessionStart hook for llm-wiki-compiler plugin
# Detects .wiki-compiler.json and injects wiki context based on mode
# Modified: python3 instead of node, supports absolute source paths

set -euo pipefail

# Walk up from $PWD to find .wiki-compiler.json
config_file=""
dir="$PWD"
while [ "$dir" != "/" ]; do
  if [ -f "$dir/.wiki-compiler.json" ]; then
    config_file="$dir/.wiki-compiler.json"
    break
  fi
  dir="$(dirname "$dir")"
done

# No config found — exit silently
if [ -z "$config_file" ]; then
  exit 0
fi

project_root="$(dirname "$config_file")"

# Read config values using python3 (works on macOS without node)
read_config() {
  python3 -c "import json; c=json.load(open('$config_file')); print(c.get('$1', '$2'))" 2>/dev/null || echo "$2"
}

output_path=$(read_config "output" "")
mode=$(read_config "mode" "staging")
name=$(read_config "name" "Project")

if [ -z "$output_path" ]; then
  exit 0
fi

# Support both relative and absolute output paths
if [[ "$output_path" = /* ]]; then
  index_file="$output_path/INDEX.md"
  state_file="$output_path/.compile-state.json"
else
  index_file="$project_root/$output_path/INDEX.md"
  state_file="$project_root/$output_path/.compile-state.json"
fi

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

if [ ! -f "$index_file" ]; then
  context="[Wiki Compiler] Wiki configured for \"$name\" but not yet compiled. Run /wiki-compile to build your knowledge base."
else
  topic_count=$(python3 -c "import json; print(len(json.load(open('$state_file')).get('topics',[])))" 2>/dev/null || echo "?")
  last_compiled=$(python3 -c "import json; print(json.load(open('$state_file')).get('last_compiled','unknown'))" 2>/dev/null || echo "unknown")

  # Count stale files
  stale_count=0
  source_dirs=$(python3 -c "
import json, os
c = json.load(open('$config_file'))
root = '$project_root'
for s in c.get('sources', []):
    p = s.get('path', '')
    if p.startswith('/'):
        print(p)
    else:
        print(os.path.join(root, p))
" 2>/dev/null || echo "")

  for sd in $source_dirs; do
    [ ! -d "$sd" ] && continue
    count=$(find "$sd" \( -name "*.md" -o -name "*.py" \) -newer "$state_file" 2>/dev/null | wc -l | tr -d ' ')
    stale_count=$((stale_count + count))
  done

  stale_msg=""
  if [ "$stale_count" -gt 0 ]; then
    stale_msg=" | ⚠ ${stale_count} files changed since last compile"
  fi

  case "$mode" in
    staging)
      context="[Wiki Compiler] Knowledge wiki available for \"$name\".\nLocation: $output_path\nTopics: $topic_count | Last compiled: $last_compiled${stale_msg}\nMode: staging\n\nFor project context, read ${output_path}/INDEX.md to see available topics, then read specific topic articles. One topic article replaces reading 10-20 raw files.\n\nCoverage tags tell you when to trust wiki vs read raw files:\n- [coverage: high] — trust this section\n- [coverage: medium] — good overview, check raw for detail\n- [coverage: low] — read raw sources\n\nWiki articles are read-only — regenerated by /wiki-compile."
      ;;
    recommended)
      context="[Wiki Compiler] \"$name\" knowledge wiki active.\nLocation: $output_path\nTopics: $topic_count | Last compiled: $last_compiled${stale_msg}\nMode: recommended — READ WIKI FIRST\n\nAt session start, read ${output_path}/INDEX.md. Read topic articles BEFORE reading raw source files or code. Fall back to raw sources only for [coverage: low] sections or granular code-level detail.\n\nWiki articles are read-only — regenerated by /wiki-compile."
      ;;
    primary)
      context="[Wiki Compiler] \"$name\" wiki is the PRIMARY knowledge source.\nLocation: $output_path\nTopics: $topic_count | Last compiled: $last_compiled${stale_msg}\n\nREQUIRED: Read ${output_path}/INDEX.md at session start. Only read raw source files when a wiki article's Sources section points you there.\n\nWiki articles are read-only — regenerated by /wiki-compile."
      ;;
    *)
      context="[Wiki Compiler] Wiki available for \"$name\" at $output_path ($topic_count topics, last compiled: $last_compiled). Run /wiki-compile to update."
      ;;
  esac
fi

escaped_context=$(escape_for_json "$context")

# Output in correct format per platform
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$escaped_context"
fi

exit 0
